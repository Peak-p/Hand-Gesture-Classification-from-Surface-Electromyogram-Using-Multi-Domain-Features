# --- Helper function to plot confusion matrix ---
def plot_confusion_matrix(y_true, y_pred, labels, title="Confusion Matrix"):
    """
    Generates and displays a heatmap of the confusion matrix.
    """
    if len(np.unique(y_true)) < 2:  
        print(f"⚠️ Skipping confusion matrix plot for '{title}': Not enough unique true labels.")
        return

    cm = confusion_matrix(y_true, y_pred, labels=labels)
    display_labels = [f'Grasp {l + 1}' for l in labels]

    plt.figure(figsize=(12, 10))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',      
                xticklabels=display_labels, yticklabels=display_labels,
                annot_kws={"size": 10})
    
    plt.title(title, fontsize=14)
    plt.xlabel('Predicted Label', fontsize=12)
    plt.ylabel('True Label', fontsize=12)
    
    plt.xticks(rotation=45, ha='right', fontsize=10)
    plt.yticks(rotation=0, fontsize=10)

    plt.tight_layout()
    filename = re.sub(r'[^\w\s.-]', '', title).replace(' ', '_').replace('__', '_') + ".png"  
    plot_path = os.path.join(output_plot_folder, filename)
    plt.savefig(plot_path)
    print(f"✅ Confusion matrix saved to: {plot_path}")
    plt.close('all') 

def plot_scenario2_accuracy(results_summary, plot_folder, filename="scenario2_accuracy_comparison.png"):
    """
    Generates and saves a bar chart comparing Accuracy for Scenario 2 only.
    Includes error bars if standard deviation is available.
    """
    plot_data = []
    
    scenario_2_key_phrase = f"Inter-subject {n_splits_subject_cv}-Fold CV"
    
    filtered_results_summary = {
        k: v for k, v in results_summary.items() 
        if scenario_2_key_phrase in k
    }

    for model_scenario, metrics in filtered_results_summary.items(): 
        parts = model_scenario.split(' (')
        model_name = parts[0]
        
        group_name_match = re.search(r'\((inact|imputee|All Subjects)\)', model_scenario) 
        group_name = group_name_match.group(1) if group_name_match else "Unknown Group"

        accuracy_str = metrics["Accuracy"].split(' ± ')[0]
        accuracy = float(accuracy_str) if accuracy_str not in ["N/A", "Error"] else np.nan
        
        std_str = metrics["Accuracy"].split(' ± ')
        std_dev = float(std_str[1]) if len(std_str) > 1 and std_str[1] != 'nan' else np.nan
        
        plot_data.append({'Model': model_name, 'Group': group_name, 'Accuracy': accuracy, 'Accuracy_SD': std_dev})

    plot_data = [d for d in plot_data if not np.isnan(d['Accuracy'])]

    if not plot_data:
        print("No Scenario 2 results found to plot accuracy.")
        return

    df_plot = pd.DataFrame(plot_data)
    
    plt.figure(figsize=(12, 7))
    sns.barplot(x='Model', y='Accuracy', hue='Group', data=df_plot, palette='magma', errorbar='sd', capsize=0.1)
    plt.title(f'Model Accuracy Comparison for Scenario 2 (Inter-subject {n_splits_subject_cv}-Fold CV)', fontsize=14) 
    plt.xlabel('Model', fontsize=12)
    plt.ylabel('Accuracy (%)', fontsize=12)
    plt.ylim(0, 100)
    plt.grid(axis='y', linestyle='--', alpha=0.7)
    plt.legend(title='Group')
    plt.tight_layout()

    plot_path = os.path.join(plot_folder, filename)
    plt.savefig(plot_path)
    print(f"✅ Scenario 2 accuracy comparison graph saved to: {plot_path}")
